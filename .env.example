# parkinson — env-var configuration
# Copy this file to `.env` (gitignored) and adjust values.
# All variables are optional; defaults shown.

# Data root (daily/, knowledge/, reports/, projects.json live here)
# Default: <repo_root>/data
# PARKINSON_DATA_DIR=~/my-knowledge-base

# Timezone for today_iso() / now_iso(). Default: system local time.
# Set to a IANA tz name (e.g. "Europe/Moscow", "UTC") to override.
# PARKINSON_TIMEZONE=Europe/Moscow

# Compact warning (strategic compaction suggestions)
# PARKINSON_COMPACT_THRESHOLD=50
# PARKINSON_COMPACT_INTERVAL=25

# Flush tuning
# PARKINSON_FLUSH_MAX_CONTEXT_CHARS=150000
# PARKINSON_FLUSH_COOLDOWN_SEC=30

# Observations (PreToolUse/PostToolUse) rotation
# PARKINSON_OBSERVATIONS_MAX_MB=10

# AgentShield security scan throttling
# PARKINSON_AGENTSHIELD_THROTTLE_H=6
# PARKINSON_AGENTSHIELD_TIMEOUT_S=60

# Instinct synthesis window
# PARKINSON_INSTINCT_MIN_OBS=20
# PARKINSON_INSTINCT_WINDOW_H=24

# Logging
# PARKINSON_LOG_LEVEL=INFO

# Anthropic API (only needed if your Claude subscription does not cover
# Claude Agent SDK — Max/Team/Enterprise subscriptions include it).
# ANTHROPIC_API_KEY=sk-ant-...
